# =============================================================================
# 공공데이터포털 - 금융위원회_주식시세정보
# https://www.data.go.kr → 마이페이지 → Open API → 일반 인증키 (Decoding)
# =============================================================================

DATA_GO_KR_SERVICE_KEY=bd3c9097a413c2a9ac313b5d3f784c5ca4a33866e6c836dc69d107a9b252a38d

# Base URL (Swagger: GetStockSecuritiesInfoService)
DATA_GO_KR_STOCK_BASE_URL=https://apis.data.go.kr/1160100/service/GetStockSecuritiesInfoService

# 오퍼레이션 Endpoint (Base URL 뒤에 붙여 사용)
DATA_GO_KR_STOCK_PRICE_ENDPOINT=/getStockPriceInfo
DATA_GO_KR_SECURITIES_PRICE_ENDPOINT=/getSecuritiesPriceInfo
DATA_GO_KR_PREEMPTIVE_RIGHT_SECURITIES_ENDPOINT=/getPreemptiveRightSecuritiesPriceInfo
DATA_GO_KR_PREEMPTIVE_RIGHT_CERTIFICATE_ENDPOINT=/getPreemptiveRightCertificatePriceInfo

# =============================================================================
# 해외 주식 시세 (yfinance - API 키 불필요)
# https://github.com/ranaroussi/yfinance
# =============================================================================

# Yahoo Finance 티커 (쉼표 구분)
# MU=마이크론, WDC=웨스턴 디지털, STX=시게이트
US_STOCK_TICKERS=MU,WDC,STX

# 일본 주식 (yfinance, JPY -> KRW 환산)
# 285A.T=키옥시아 (도쿄증권거래소, 2024년 12월 상장)
JP_STOCK_TICKERS=285A.T

# =============================================================================
# 포트폴리오 설정
# =============================================================================

# 국내 종목 단축코드 (쉼표 구분) — 005930=삼성전자, 000660=SK하이닉스
KR_STOCK_CODES=005930,000660

# 분석 기준 금액 (원)
PORTFOLIO_AMOUNT_KRW=100000000

# 과거 데이터 조회 기간 (영업일 기준, 약 1년)
LOOKBACK_DAYS=252

# 연도별 수익률 분석 시작 연도
ANNUAL_START_YEAR=2002
